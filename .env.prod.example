###############################################################################
# Plantilla de entorno para el deploy (DEV desplegado / producción).
#
# Copiá este archivo a `.env` EN EL DROPLET (/opt/santosha/.env) y completá los
# valores reales. El `.env` real NUNCA se commitea (está en .gitignore) ni entra
# a la imagen: vive solo en el server.
###############################################################################

APP_NAME="Santosha ERP"
APP_ENV=production
# Generar una vez y pegar acá (ver runbook docs/DEPLOY.md):
#   echo "base64:$(openssl rand -base64 32)"
APP_KEY=
APP_DEBUG=false
APP_URL=https://santosha.dev.umbralclub.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_CURRENCY=PYG

# --- Imagen a desplegar (la publica el workflow en GHCR) ---
APP_IMAGE=ghcr.io/santoshadevel/republica-de-la-paz-app:dev

# --- Caddy / TLS (Let's Encrypt) ---
APP_DOMAIN=santosha.dev.umbralclub.com
ACME_EMAIL=devops@umbralclub.com

# --- Base de datos: cluster MySQL 8 administrado de DigitalOcean ---
# El cluster está COMPARTIDO con UmbralClub: usar base y usuario propios de Santosha,
# nunca `defaultdb` / `doadmin` (ver docs/DEPLOY.md, paso 0.2).
# El puerto administrado NO es 3306 (suele ser 25060) y exige SSL.
DB_CONNECTION=mysql
DB_HOST=db-mysql-nyc1-93329-do-user-000000-0.k.db.ondigitalocean.com
DB_PORT=25060
DB_DATABASE=santosha_dev
DB_USERNAME=santosha
DB_PASSWORD=
# Certificado CA del cluster, montado dentro del contenedor (ver runbook).
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/mysql-ca.crt

# --- Logs ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Sesión / cache / colas (usan tablas de la DB; las crean las migraciones) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# --- Correo: verificación de email del portal del alumno ---
# Por ahora al log; configurar un SMTP real (Mailgun/Postmark/etc.) antes de
# habilitar registros reales.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@umbralclub.com"
MAIL_FROM_NAME="${APP_NAME}"
