###############################################################################
# Configuración de Caddy (TLS + protección del demo).
#
# Copiar a `.caddy.env` EN EL DROPLET (/opt/santosha/.caddy.env).
# Va separado del .env de Laravel por dos razones:
#   1. el hash bcrypt contiene `$`, que la interpolación de docker compose
#      mastica si se pasa por `environment:`;
#   2. así las credenciales de la base no quedan expuestas dentro del
#      contenedor de Caddy.
###############################################################################

# Dominio del entorno (Caddy pide el certificado TLS para este nombre).
APP_DOMAIN=santosha.dev.umbralclub.com

# Email para Let's Encrypt (avisos de expiración).
ACME_EMAIL=devops@umbralclub.com

# --- Protección del demo (basic auth) ---
# Quien entre a la URL verá un prompt de usuario/contraseña antes de la app.
DEMO_USER=santosha

# Hash bcrypt de la contraseña. NO se pone la contraseña en texto plano.
#
# ⚠️ OJO: docker compose interpola `$` en este archivo, y el hash bcrypt está lleno
# de `$` (formato `$2a$14$...`). Hay que ESCAPARLOS duplicándolos (`$` -> `$$`),
# si no el hash llega roto al contenedor y nadie puede entrar.
#
# Este comando genera el hash YA ESCAPADO, listo para pegar:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'TU_PASSWORD' | sed 's/\$/$$/g'
#
# Debe quedar así (con dobles $$):
#   DEMO_PASSWORD_HASH=$$2a$$14$$Xq1vYhJ5nO7pR3uOeK9wL2mN4bC6dE8fG0hI2jK4lM6nO8q
DEMO_PASSWORD_HASH=
